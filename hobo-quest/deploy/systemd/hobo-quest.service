[Unit]
Description=HoboQuest — Community MMORPG & Canvas
After=network.target

[Service]
Type=simple
User=deck
WorkingDirectory=/opt/hobo-quest
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /opt/hobo-quest/server/index.js
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/hobo-quest/data

[Install]
WantedBy=multi-user.target
