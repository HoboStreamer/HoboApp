# ═══════════════════════════════════════════════════════════════
# hobo.quest — Environment Configuration
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

PORT=3200
NODE_ENV=production

# OAuth2 client secret (generated by hobo.tools on first run — check its console output)
OAUTH_CLIENT_SECRET=paste-from-hobo-tools-console

# Internal API key — must match hobo.tools
INTERNAL_API_KEY=change-me-to-a-random-64-char-string

# RSA public key path (copy from hobo.tools/data/keys/public.pem)
RSA_PUBLIC_KEY_PATH=data/keys/public.pem

# Database
DB_PATH=data/hobo-quest.db

# hobo.tools internal API
HOBO_TOOLS_URL=http://127.0.0.1:3100
