# ═══════════════════════════════════════════════════════════════
# hobo.tools — Environment Configuration
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# Server
PORT=3100
NODE_ENV=production
BASE_URL=https://hobo.tools
HOBO_TOOLS_URL=https://hobo.tools
HOBO_TOOLS_INTERNAL_URL=http://127.0.0.1:3100

# Security — CHANGE THESE IN PRODUCTION
# Internal API key shared between hobo.tools, hobostreamer, and hobo.quest
INTERNAL_API_KEY=change-me-to-a-random-64-char-string
SETUP_TOKEN=change-me-to-a-second-random-secret
BOOTSTRAP_PROFILE=single-node-prod

# Admin account auto-created on first run
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Paths (relative to project root)
DB_PATH=data/hobo-tools.db
RSA_PRIVATE_KEY_PATH=data/keys/private.pem
RSA_PUBLIC_KEY_PATH=data/keys/public.pem

# Connected services (internal, not proxied through Cloudflare)
HOBOSTREAMER_INTERNAL_URL=http://127.0.0.1:3000
HOBOQUEST_INTERNAL_URL=http://127.0.0.1:3200

# ═══════════════════════════════════════════════════════════════
# Amazon SES — Email Notifications (optional)
#
# Only used for CRITICAL priority notifications (moderation, system alerts).
# Can also be configured at runtime via the admin panel at /api/admin/ses.
# If left blank here, configure through the admin panel instead.
# ═══════════════════════════════════════════════════════════════
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=noreply@hobo.tools
SES_FROM_NAME=Hobo Network

# ═══════════════════════════════════════════════════════════════
# Notifications
# ═══════════════════════════════════════════════════════════════
# Enable/disable the notification system globally
NOTIFICATIONS_ENABLED=true
# Days to keep old notifications before cleanup (default: 30)
NOTIFICATION_MAX_AGE_DAYS=30
# Only send emails for CRITICAL priority notifications (recommended)
NOTIFICATION_EMAIL_CRITICAL_ONLY=true

# ═══════════════════════════════════════════════════════════════
# RSA Key Generation (run once during setup):
#
#   mkdir -p data/keys
#   openssl genrsa -out data/keys/private.pem 2048
#   openssl rsa -in data/keys/private.pem -pubout -out data/keys/public.pem
#
# The private key stays on hobo.tools only.
# Copy public.pem to hobostreamer and hobo-quest for token verification.
# ═══════════════════════════════════════════════════════════════
