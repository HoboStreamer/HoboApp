[Unit]
Description=HoboTools — Central Hub & SSO
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/hobo-tools
Environment=NODE_ENV=production
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/env node /opt/hobo-tools/server/index.js
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/hobo-tools/data

[Install]
WantedBy=multi-user.target
